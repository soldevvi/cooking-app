<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Метка таймера -->
        <TextView
            android:id="@+id/tvTimerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:text="Timer"
            android:layout_marginBottom="6dp"/>

        <!-- Большие цифры обратного отсчёта -->
        <TextView
            android:id="@+id/tvTimerTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="46sp"
            android:textStyle="bold"
            android:textColor="@color/colorText"
            android:gravity="center"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp"/>

        <!-- Кнопки: Старт / Пауза / Сброс -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTimerStart"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/timer_start"
                android:textSize="13sp"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTimerPause"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/timer_pause"
                android:textSize="13sp"
                app:strokeColor="@color/colorPrimary"
                android:textColor="@color/colorPrimary"
                app:cornerRadius="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTimerReset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="@string/timer_reset"
                android:textSize="13sp"
                app:strokeColor="#9E9E9E"
                android:textColor="#616161"
                app:cornerRadius="10dp"/>

        </LinearLayout>

        <!-- Блок ввода времени (только для editable-таймеров) -->
        <LinearLayout
            android:id="@+id/editableSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_set_minutes"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTimerCustomTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="@string/timer_minutes_hint"
                    android:textSize="14sp"
                    android:maxLength="3"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTimerSetTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/timer_apply"
                android:textSize="12sp"
                android:backgroundTint="@color/colorAccent"
                android:textColor="@color/colorPrimary"
                app:cornerRadius="8dp"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
